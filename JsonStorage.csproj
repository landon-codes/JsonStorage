<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <OutputType>Library</OutputType>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>

    <PackageId>landon-codes.JsonStorage</PackageId>
    <Version>1.1.1</Version>
    <Authors>landon-codes</Authors>
    <Description>This contains functions for creating and managing json files in your .net project.</Description>

    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/landon-codes/JsonStorage</RepositoryUrl>
    <PackageTags>csharp json data file-manipulation</PackageTags>
    <!-- <PackageIcon></PackageIcon -->
  </PropertyGroup>

</Project>
